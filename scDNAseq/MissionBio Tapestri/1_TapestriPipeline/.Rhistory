library(yaml)
temp = yaml.load_file('config_template.yaml')
samples = readLines('samples.txt')
replace_sample_recursive <- function(obj, sample_name) {
if (is.character(obj)) {
# Replace "sample" in character strings
return(gsub("sample", sample_name, obj))
} else if (is.list(obj)) {
# Recurse over lists
return(lapply(obj, replace_sample_recursive, sample_name))
} else {
# Return other types of objects unchanged
return(obj)
}
}
for (sample in samples) {
cat(paste0('Creating config for sample ', sample, '\n'))
f = lapply(temp, replace_sample_recursive, sample)
fp = paste0(sample, '_config.yaml')
write(yaml::as.yaml(f), fp)
cat(paste0('Sample ', sample, ' config completed and saved.\n'))
}
